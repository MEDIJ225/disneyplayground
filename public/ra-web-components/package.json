{
  "name": "@wdpr/ra-web-components",
  "version": "3.0.6",
  "description": "RA Web Component Library",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/wdpr-ra-web-components/wdpr-ra-web-components.esm.js",
  "exports": {
    ".": {
      "import": "./dist/wdpr-ra-web-components/wdpr-ra-web-components.esm.js",
      "require": "./dist/wdpr-ra-web-components/wdpr-ra-web-components.cjs.js",
      "types": "./dist/types/index.d.ts"
    },
    "./dist/*": {
      "import": "./dist/*",
      "require": "./dist/*"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    },
    "./hydrate": {
      "import": "./hydrate/index.mjs",
      "require": "./hydrate/index.cjs",
      "types": "./hydrate/index.d.ts"
    },
    "./global/vista-base.css": {
      "default": "./dist/wdpr-ra-web-components/global/vista-base.css"
    },
    "./global/styles.css": {
      "default": "./dist/wdpr-ra-web-components/global/styles.css"
    },
    "./themes/cast-theme.css": {
      "default": "./dist/wdpr-ra-web-components/global/themes/cast-theme.css"
    },
    "./themes/dcl-theme.css": {
      "default": "./dist/wdpr-ra-web-components/global/themes/dcl-theme.css"
    },
    "./themes/parks-now-theme.css": {
      "default": "./dist/wdpr-ra-web-components/global/themes/parks-now-theme.css"
    },
    "./themes/parks-next-theme.css": {
      "default": "./dist/wdpr-ra-web-components/global/themes/parks-next-theme.css"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/",
    "loader/",
    "hydrate/"
  ],
  "scripts": {
    "icons:generate": "node scripts/generate-icon-loaders.js",
    "prebuild": "npm run icons:generate",
    "component-manifest": "node scripts/generate-component-manifest.js --packageDir ./ --src src/components --out dist/component-manifest.json",
    "component-version-map": "node scripts/update-storybook-versions.js",
    "component-changelog": "node scripts/merge-component-changelogs.js",
    "dev": "concurrently \"npm run dev:tailwind\" \"npm run dev:stencil\"",
    "build": "npm run tailwind && stencil build --docs && npm run component-manifest && npm run component-version-map",
    "dev:stencil": "stencil build --watch",
    "dev:tailwind": "tailwindcss -i ./src/global/tailwind.css -o ./src/global/styles.css -m --watch",
    "tailwind": "tailwindcss -i ./src/global/tailwind.css -o ./src/global/styles.css -m",
    "test": "stencil test --spec",
    "test.watch": "stencil test --spec --watchAll",
    "test.coverage": "stencil test --spec --coverage",
    "lint": "eslint --ext .ts,.tsx src/",
    "generate": "stencil generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@rive-app/canvas": "~2.36.0",
    "date-fns": "^4.1.0",
    "lottie-web": "~5.13.0",
    "qrcode": "^1.5.4",
    "tailwind-merge": "~3.3.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "~18.2.0",
    "@angular-eslint/eslint-plugin": "~18.2.0",
    "@angular-eslint/eslint-plugin-template": "~18.2.0",
    "@angular-eslint/schematics": "~18.2.0",
    "@angular-eslint/template-parser": "~18.2.0",
    "@stencil-community/eslint-plugin": "~0.10.0",
    "@stencil/angular-output-target": "~1.1.1",
    "@stencil/core": "~4.36.2",
    "@stencil/react-output-target": "1.2.0",
    "@tailwindcss/cli": "~4.1.11",
    "@types/jest": "~29.5.14",
    "@types/node": "~24.2.1",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "~7.0.0",
    "@typescript-eslint/parser": "~7.0.0",
    "concurrently": "~9.2.0",
    "eslint": "~8.57.0",
    "jest": "~29.7.0",
    "jest-cli": "~29.7.0",
    "puppeteer": "~22.10.0",
    "tailwindcss": "~4.1.11"
  },
  "license": "MIT"
}
